{
  "name": "typescript-cypress-template",
  "version": "1.0.0",
  "description": "Template-For Typescript with Linting for cypress ,Integrated Allure report",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cy:run": "cypress run",
    "clean": "rimraf allure-results allure-report",
    "UR:run": "node split-runner.js",
    "UR:singleThread": "npx cypress run || node -e \"process.exit(0)\"",
    "copy:history": "shx mkdir -p allure-results && shx cp -r allure-report/history allure-results/ || node -e \"process.exit(0)\"",
    "UR:report": "allure generate allure-results --clean && node customiseAllureReports.ts",
    "UR:open": "npx allure open",
    "UR": "yarn copy:history && yarn UR:singleThread && yarn UR:report && yarn UR:open"
  },
  "type": "module",
  "author": "Ujjwal Raj",
  "license": "ISC",
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^7.0.1",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.1.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "cypress": "^15.10.0",
    "cypress-xpath": "^2.0.1",
    "dayjs": "^1.11.19",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^5.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
